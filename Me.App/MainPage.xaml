<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Me.App"
             xmlns:components="clr-namespace:Me.App.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Me.App.MainPage"
               SafeAreaEdges="All">
    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="#FDF9F0" StatusBarStyle="DarkContent" />
    </ContentPage.Behaviors>
    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
