@using Flowbite.Components.Chat
@using Flowbite.Icons
@using Me.App.Core.UserAgg
@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="relative flex h-screen flex-col overflow-hidden bg-[#fff8f4]">

    <div id="floating-header" class="header-safe pointer-events-none fixed top-0 right-0 left-0 z-40 px-4 transition-transform duration-500 ease-in-out">
        <header class="pointer-events-auto flex items-center justify-between rounded-full border border-gray-100/50 bg-white/85 px-5 py-2 shadow-lg shadow-gray-200/40 backdrop-blur-md">
            <div class="flex items-center gap-3">
                <span class="pl-2 font-extrabold tracking-tight text-gray-800"> .ME </span>
            </div>
            <button class="rounded-full p-2 text-slate-400 transition-all hover:text-primary active:scale-95">
                <GearIcon class="h-6 w-6" />
            </button>
        </header>
    </div>

    <main id="main-scroll-container" class="relative z-0 flex-1 overflow-x-hidden overflow-y-auto pt-28 pb-32">
        <div class="mx-auto h-full max-w-md px-4">
            @Body
        </div>
    </main>

    <div class="home-indicator-safe fixed right-4 bottom-6 left-4 z-50">
        <nav class="mx-auto flex max-w-md items-center justify-between rounded-[2rem] border border-gray-50 bg-white p-2 shadow-xl shadow-gray-200/60">

            <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                <div class="nav-icon-wrapper"><HomeIcon /></div>
                <span class="nav-text">Home</span>
            </NavLink>

            <NavLink href="/search" class="nav-link">
                <div class="nav-icon-wrapper"><SearchIcon /></div>
                <span class="nav-text">Search</span>
            </NavLink>

            <NavLink href="/upload" class="nav-link">
                <div class="nav-icon-wrapper">
                    <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14m-7-7h14" />
                    </svg>
                </div>
                <span class="nav-text">Add</span>
            </NavLink>

            <NavLink href="/saved" class="nav-link">
                <div class="nav-icon-wrapper">
                    <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m16 10 3-3m0 0-3-3m3 3H5v3m3 4-3 3m0 0 3 3m-3-3h14v-3" />
                    </svg>
                </div>
                <span class="nav-text">Back up</span>
            </NavLink>

            <NavLink href="/profile" class="nav-link">
                <div class="nav-icon-wrapper"><UserIcon /></div>
                <span class="nav-text">Profile</span>
            </NavLink>

        </nav>
    </div>
</div>

<style>

    .status-bar-safe {
        padding-top: calc(1rem + env(safe-area-inset-top, 32px));
    }
    
    .header-safe {
        padding-top: calc(env(safe-area-inset-top, 24px) + 12px);
    }
    
    .home-indicator-safe {
        padding-bottom: env(safe-area-inset-bottom, 10px);
    }
    .header-hidden {
        transform: translateY(-150%);
    }
    .nav-link {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem;
        border-radius: 9999px; 
        color: #9CA3AF; 
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

        .nav-link:active {
            transform: scale(0.95);
        }

        .nav-link.active {
            color: var(--color-primary);
            background-color: color-mix(in srgb, var(--color-primary) 20%, transparent);
        }

    .nav-icon-wrapper svg {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        transition: color 0.3s ease;
    }

    .nav-text {
        font-size: 0.875rem;
        font-weight: 600;
        white-space: nowrap;
        max-width: 0;
        opacity: 0;
        margin-left: 0;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link.active .nav-text {
        max-width: 100px;
        opacity: 1;
        margin-left: 0.5rem;
        padding-right: 0.25rem;
    }
</style>


@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {

            await JS.InvokeVoidAsync("meUI.initScrollHeader", "main-scroll-container", "floating-header");
        };



    }
}