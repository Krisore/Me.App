@page "/"
@using Me.App.Core.VehicleAggregate
@using Me.App.Core.UserAgg
@using Me.App.Infrastructure
@inject IVehicleService VehicleService
@inject IUserService UserService
@inject NavigationManager NavManager

@if (_isCheckingProfile)
{
    <div class="flex h-full items-center justify-center">
        <div class="animate-pulse text-gray-400">Opening Garage...</div>
    </div>
}
else
{
    <div class="flex flex-col gap-6 pb-10">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500">Good morning, @_userProfile?.Nickname</p>
                <h1 class="text-2xl font-bold text-gray-800">Your Garage</h1>
            </div>
        </div>

        @* THE GARAGE DOOR ANIMATION *@
        <div class="relative h-56 w-full cursor-pointer overflow-hidden rounded-2xl shadow-2xl shadow-gray-200" @onclick="ToggleGarage">

            <div class="absolute inset-0 overflow-hidden bg-black">

                <img src="./_assets/pixel-garage.png" alt="Garage Interior" class="absolute inset-0 h-full w-full object-cover" />

                <div class="absolute bottom-[0px] left-[295px] z-10 cursor-pointer transition-transform hover:scale-105 active:scale-95"
                     @onclick:stopPropagation="true"
                     @onclick="PokeMechanic">

                    <div class="absolute -top-12 left-0 w-36 rounded-lg bg-white p-2 text-center shadow-xl transition-all duration-300 @(showMechanicTip ? "translate-y-0 opacity-100" : "translate-y-2 opacity-0 pointer-events-none")">
                        <p class="font-headline leading-tight font-bold text-[10px] text-gray-800">
                            @currentTip
                        </p>
                        <div class="absolute -bottom-1 left-6 h-2 w-2 rotate-45 bg-white"></div>
                    </div>

                    <img src="./_assets/mechanic.png" class="h-20 w-auto drop-shadow-2xl" alt="Mechanic Mascot" />
                </div>

            </div>

            <div class="garage-door-texture absolute inset-0 z-20 flex flex-col items-center justify-center border-b-8 border-gray-900 transition-transform duration-700 ease-in-out @(isGarageOpen ? "-translate-y-full" : "translate-y-0")">
                <div class="mb-4 rounded-lg border border-gray-700 bg-gray-900 px-4 py-2 shadow-inner">
                    <svg class="h-6 w-6 text-gray-400 @(isGarageOpen ? "hidden" : "block")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <h3 class="text-lg font-black tracking-widest text-gray-300 drop-shadow-md">YOUR GARAGE</h3>
                <p class="mt-1 animate-pulse text-xs font-bold tracking-widest text-blue-400">TAP TO OPEN</p>
            </div>

        </div>
        @* VEHICLE LIST SECTION *@
        <div class="mt-4 flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-bold text-gray-800">Listed Vehicles</h2>
                <button class="text-sm font-semibold text-blue-600">View All</button>
            </div>

            @if (_userVehicles == null)
            {
                <div class="flex animate-pulse flex-col gap-3">
                    <div class="h-20 w-full rounded-xl bg-gray-200"></div>
                    <div class="h-20 w-full rounded-xl bg-gray-200"></div>
                </div>
            }
            else if (!_userVehicles.Any())
            {
                <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-gray-300 bg-gray-50 py-10">
                    <svg class="mb-3 h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    <p class="text-sm font-medium text-gray-500">Your garage is empty</p>
                    <a href="/upload" class="mt-2 text-sm font-bold text-blue-600">Add a vehicle</a>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-3">
                    @foreach (var vehicle in _userVehicles)
                    {
                        <div @onclick="() => NavigateToVehicle(vehicle.Id)" class="transition-active flex items-center justify-between rounded-xl border border-gray-100 bg-white p-4 shadow-sm active:scale-95">
                            <div class="flex items-center gap-4">
                                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-500/10 text-blue-500">
                                    @if (vehicle.Type?.ToLower() == "motorcycle" || vehicle.Type?.ToLower() == "bike")
                                    {
                                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h8M8 11h8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                        </svg>
                                    }
                                </div>
                                <div>
                                    <h3 class="line-clamp-1 font-bold text-gray-800">
                                        @(string.IsNullOrWhiteSpace(vehicle.Nickname) ? $"{vehicle.Brand} {vehicle.Name}" : vehicle.Nickname)
                                    </h3>
                                    <p class="text-xs text-gray-500">Plate: @vehicle.PlateNumber • ODO: @vehicle.CurrentOdometer.ToString("N0") @vehicle.DistanceUnit</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>

    .garage-door-texture {
        background-color: #374151; /* Tailwind gray-700 */
        background-image: repeating-linear-gradient( to bottom, transparent, transparent 24px, rgba(0, 0, 0, 0.4) 24px, rgba(0, 0, 0, 0.4) 26px );
        box-shadow: inset 0 10px 15px -3px rgba(0, 0, 0, 0.5);
    }

    .perspective-1000 {
        perspective: 1000px;
    }

    .transform-style-3d {
        transform-style: preserve-3d;
    }

    .backface-hidden {
        backface-visibility: hidden;
    }

    .rotate-y-180 {
        transform: rotateY(180deg);
    }
</style>

@code {
    private bool _isCheckingProfile = true;

    private User? _userProfile;

    // Updated to use the new Vehicle entity
    private List<Vehicle>? _userVehicles;
    private Vehicle? _primaryVehicle => _userVehicles?.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        _isCheckingProfile = true;
        await Task.Delay(300);

        // Fetch User
        _userProfile = await UserService.GetUserAsync();

        if (_userProfile == null)
        {
            await Task.Delay(50);
            NavManager.NavigateTo("/welcome", true);
            return;
        }

        // Fetch all vehicles from the newly pivoted database
        _userVehicles = await VehicleService.GetVehiclesAsync();
        if(_userVehicles.Any())
        {
            isGarageOpen = true;
        }

        _isCheckingProfile = false;
    }

    private bool isGarageOpen = false;

    // Rename this method
    private void ToggleGarage()
    {
        isGarageOpen = !isGarageOpen;
    }


    private void NavigateToVehicle(int id)
    {
        NavManager.NavigateTo($"/vehicle/{id}", true);
    }
    private bool showMechanicTip = false;
    private string currentTip = "Check tire pressure!";

    private List<string> mechanicTips = new()
    {
        "Don't skip that oil change!",
        "Check your tire pressure.",
        "Brake pads looking thin?",
        "Clean your air filter soon.",
        "Chain needs lubing!"
    };

    private async Task PokeMechanic()
    {
        var random = new Random();
        currentTip = mechanicTips[random.Next(mechanicTips.Count)];

        showMechanicTip = true;
        StateHasChanged();

        await Task.Delay(3000); // Bubble disappears after 3 seconds
        showMechanicTip = false;
        StateHasChanged();
    }
}